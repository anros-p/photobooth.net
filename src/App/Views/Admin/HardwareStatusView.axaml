<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Photobooth.App.ViewModels.Admin"
             x:Class="Photobooth.App.Views.Admin.HardwareStatusView"
             x:DataType="vm:HardwareStatusViewModel">

  <StackPanel Spacing="20" Margin="16">

    <Button Content="Refresh"
            Command="{Binding RefreshCommand}"
            IsEnabled="{Binding !IsRefreshing}" />

    <Border Background="#1E1E1E" CornerRadius="8" Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Camera" FontWeight="SemiBold" FontSize="16" />
        <Grid ColumnDefinitions="120,*">
          <TextBlock Grid.Column="0" Text="Model:" Foreground="Gray" />
          <TextBlock Grid.Column="1" Text="{Binding CameraModel}" />
        </Grid>
        <Grid ColumnDefinitions="120,*">
          <TextBlock Grid.Column="0" Text="Status:" Foreground="Gray" />
          <TextBlock Grid.Column="1" Text="{Binding CameraStatus}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Background="#1E1E1E" CornerRadius="8" Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Printer" FontWeight="SemiBold" FontSize="16" />
        <Grid ColumnDefinitions="120,*">
          <TextBlock Grid.Column="0" Text="Status:" Foreground="Gray" />
          <TextBlock Grid.Column="1" Text="{Binding PrinterStatus}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Background="#1E1E1E" CornerRadius="8" Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Storage" FontWeight="SemiBold" FontSize="16" />
        <Grid ColumnDefinitions="120,*">
          <TextBlock Grid.Column="0" Text="Free space:" Foreground="Gray" />
          <TextBlock Grid.Column="1" Text="{Binding DiskFree}" />
        </Grid>
      </StackPanel>
    </Border>

  </StackPanel>

</UserControl>
