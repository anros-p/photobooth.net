<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Photobooth.App.ViewModels.Kiosk"
             x:Class="Photobooth.App.Views.Kiosk.ReviewView"
             x:DataType="vm:ReviewViewModel"
             Background="Black">

  <Grid RowDefinitions="*,Auto">

    <!-- Composed photo -->
    <Image Grid.Row="0"
           Source="{Binding ComposedImage}"
           Stretch="Uniform"
           Margin="0,24,0,0" />

    <!-- Action bar -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="24"
                Margin="0,24,0,48">

      <Button Content="{Binding RetakeLabel}"
              Command="{Binding RetakeCommand}"
              FontSize="24"
              Padding="32,16" />

      <Button Content="{Binding PrintLabel}"
              Command="{Binding PrintCommand}"
              FontSize="24"
              Padding="32,16"
              IsVisible="{Binding IsPrintingEnabled}"
              IsEnabled="{Binding !IsPrinting}" />

      <Button Content="{Binding ShareLabel}"
              Command="{Binding ShareCommand}"
              FontSize="24"
              Padding="32,16"
              IsVisible="{Binding IsSharingEnabled}" />

      <Button Content="{Binding DoneLabel}"
              Command="{Binding DoneCommand}"
              FontSize="24"
              Padding="32,16" />

    </StackPanel>

  </Grid>

</UserControl>
