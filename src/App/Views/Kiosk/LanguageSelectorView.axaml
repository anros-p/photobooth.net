<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Photobooth.App.ViewModels.Kiosk"
             x:Class="Photobooth.App.Views.Kiosk.LanguageSelectorView"
             x:DataType="vm:LanguageSelectorViewModel"
             Background="#CC000000">

  <Border Background="#2A2A2A"
          CornerRadius="16"
          Padding="32"
          Width="400"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

    <StackPanel Spacing="24">

      <TextBlock Text="{Binding SelectLabel}"
                 FontSize="28"
                 FontWeight="SemiBold"
                 Foreground="White"
                 HorizontalAlignment="Center" />

      <ItemsControl ItemsSource="{Binding AvailableLanguages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Content="{Binding DisplayName}"
                    Command="{Binding $parent[UserControl].((vm:LanguageSelectorViewModel)DataContext).SelectCommand}"
                    CommandParameter="{Binding}"
                    FontSize="22"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Margin="0,4" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Button Content="{Binding CloseLabel}"
              Command="{Binding CloseCommand}"
              FontSize="20"
              HorizontalAlignment="Center"
              Padding="24,12" />

    </StackPanel>

  </Border>

</UserControl>
