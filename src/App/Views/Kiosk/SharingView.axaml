<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Photobooth.App.ViewModels.Kiosk"
             x:Class="Photobooth.App.Views.Kiosk.SharingView"
             x:DataType="vm:SharingViewModel"
             Background="#1A1A1A">

  <ScrollViewer>
    <StackPanel Spacing="32" Margin="48" MaxWidth="600" HorizontalAlignment="Center">

      <!-- QR Code -->
      <StackPanel IsVisible="{Binding IsQrEnabled}" Spacing="16">
        <TextBlock Text="{Binding QrInstruction}"
                   FontSize="24" Foreground="White" HorizontalAlignment="Center" />
        <Image Source="{Binding QrCodePath}"
               Width="280" Height="280"
               IsVisible="{Binding QrCodePath, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <Button Content="Generate QR"
                Command="{Binding GenerateQrCommand}"
                FontSize="20" Padding="24,12"
                HorizontalAlignment="Center"
                IsVisible="{Binding QrCodePath, Converter={x:Static ObjectConverters.IsNull}}" />
      </StackPanel>

      <!-- Email -->
      <StackPanel IsVisible="{Binding IsEmailEnabled}" Spacing="12">
        <TextBox Text="{Binding EmailAddress}"
                 Watermark="{Binding EmailPlaceholder}"
                 FontSize="22" />
        <Button Content="{Binding SendLabel}"
                Command="{Binding SendEmailCommand}"
                FontSize="20" Padding="24,12"
                HorizontalAlignment="Right" />
      </StackPanel>

      <!-- SMS -->
      <StackPanel IsVisible="{Binding IsSmsEnabled}" Spacing="12">
        <TextBox Text="{Binding PhoneNumber}"
                 Watermark="{Binding PhonePlaceholder}"
                 FontSize="22" />
        <Button Content="{Binding SendLabel}"
                Command="{Binding SendSmsCommand}"
                FontSize="20" Padding="24,12"
                HorizontalAlignment="Right" />
      </StackPanel>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}"
                 FontSize="22" Foreground="LightGreen"
                 HorizontalAlignment="Center"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <Button Content="Done"
              Command="{Binding DoneCommand}"
              FontSize="24" Padding="32,16"
              HorizontalAlignment="Center" />

    </StackPanel>
  </ScrollViewer>

</UserControl>
